# --- Core ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# CSRF_TRUSTED_ORIGINS=https://snap.yourdomain.com
TIME_ZONE=UTC

# --- Database (default: sqlite file) ---
# DATABASE_URL=sqlite:///db.sqlite3

# --- Storage: local media in dev, S3 in prod ---
USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_ENDPOINT_URL=            # only for S3-compatible providers (R2, MinIO, etc.)

# --- Email: console backend in dev prints to terminal ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Prod SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.yourprovider.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Quick Snap <noreply@example.com>
